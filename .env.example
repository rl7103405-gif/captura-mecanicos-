# Copia este archivo como ".env" y rellena con los datos de tu proyecto Firebase.
# (Firebase Console -> Configuracion del proyecto -> Tus apps -> Configuracion del SDK)
# El prefijo VITE_ es obligatorio para que Vite los exponga al front.

VITE_FIREBASE_API_KEY=tu_api_key
VITE_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu-proyecto
VITE_FIREBASE_STORAGE_BUCKET=tu-proyecto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxx

# Clave VAPID para notificaciones push (FCM) - se usara en la Etapa 6.
# (Firebase Console -> Cloud Messaging -> Certificados push web)
VITE_FIREBASE_VAPID_KEY=
